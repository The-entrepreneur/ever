# ─────────────────────────────────────────────────────────────
# .gitignore — ever_agent_core monorepo
# ─────────────────────────────────────────────────────────────

# Node dependencies — never commit these
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# Environment files — contain real secrets (never commit)
.env
.env.*
*.env
*.env.*
**/.env
**/.env.*
!**/.env.example
!**/*.env.example

# Client credentials — Google service accounts, certs, keys
clients/*/credentials/
credentials/
*.pem
*.key
*.p12

# Client data (generated per deployment — not templates)
# Keep: base/templates/*.json.example
# Ignore: clients/*/data/*.xlsx  clients/*/data/*.pdf
clients/*/data/*.xlsx
clients/*/data/*.pdf

# Logs
*.log
logs/

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Build outputs / temp files
dist/
.tmp/
*.tmp

# IDE
.vscode/
.idea/

# Keep these JSON files — they are source, not secrets
!base/n8n-workflows/level1.json
!base/templates/faq.json.example
!base/templates/rooms.json.example

# ── Phase 4 additions ──────────────────────────────────────────────────────────

# PRD docs — internal strategy/product docs, not for the repo
PRD/

# Scratch / temp files — one-off scripts, test data
scratch/

# Supabase local dev artefacts
.supabase/

# .agents/skills — TRACK THIS (needed on every cloned machine)
# Do NOT add .agents/ to gitignore
