# ─────────────────────────────────────────────────────────────
# GCE (Guest Concierge Engine) — CLIENT CONFIG
# Copy this file to clients/[client-slug]/.env and fill in values
# Never commit .env files to version control
# ─────────────────────────────────────────────────────────────

# Hotel Identity
HOTEL_NAME=The Grand Horizon
HOTEL_ADDRESS=14 Harbour Lane, London
HOTEL_PHONE=+44 7700 900123
HOTEL_BOOKING_URL=https://grandhorizon.com/book
HOTEL_SLUG=grand-horizon

# ── WhatsApp ─────────────────────────────────────────────────
# WHATSAPP_PROVIDER options: openbsp | evolution | cloud_api
# OpenBSP is the primary provider. Agency-level credentials
# (OPENBSP_BASE_URL, OPENBSP_PUBLISHABLE_KEY, OPENBSP_OWNER_API_KEY)
# live in the EVER backend .env — NOT in this file.
# Per-client WhatsApp config is managed via the EVER dashboard
# and stored in the whatsapp_accounts Supabase table.
WHATSAPP_PROVIDER=openbsp

# Per-hotel values — auto-populated after Embedded Signup completes.
# Do not set these manually; they are written by the onboarding webhook.
# PHONE_NUMBER_ID=            ← Meta phone_number_id (from whatsapp_accounts)
# OPENBSP_VERIFY_TOKEN=       ← Generated at onboarding by new-client.sh
# OPENBSP_ONBOARDING_TOKEN_ID= ← Temp; remove after connection confirmed

# ── EvolutionAPI fallback (only if WHATSAPP_PROVIDER=evolution) ──────────
# EVOLUTION_BASE_URL=https://evolution.youragency.com
# EVOLUTION_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EVOLUTION_INSTANCE=hotel_slug_instance

# ── Meta Cloud API direct (only if WHATSAPP_PROVIDER=cloud_api) ─────────
# META_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxx
# META_PHONE_NUMBER_ID=your_meta_phone_number_id

# ── Meta (Instagram + Facebook) — client's own app ───────────
META_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxx
META_VERIFY_TOKEN=your_secure_verify_token_here

# ── Tawk.to — client's own account ───────────────────────────
TAWKTO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAWKTO_PROPERTY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Redis — session state (same container, bridge network) ───
REDIS_URL=redis://redis:6379

# ── n8n ──────────────────────────────────────────────────────
N8N_PORT=5679
WEBHOOK_BASE_URL=https://grand-horizon.youragency.com
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_strong_password_here

# ── Google Sheets (service account path inside container) ────
GOOGLE_SERVICE_ACCOUNT_JSON=/home/node/credentials/google-service-account.json
GOOGLE_SHEETS_ID=your_sheet_id_here

# ── Behaviour ─────────────────────────────────────────────────
DEFAULT_LANG=en
SUPPORTED_LANGS=en,fr,ar
