# ─────────────────────────────────────────────────────────────
# LEVEL 2 — GROWTH CLIENT CONFIG
# Includes all Level 1 keys plus Level 2 additions below
# ─────────────────────────────────────────────────────────────

# Hotel Identity
HOTEL_NAME=The Grand Horizon
HOTEL_ADDRESS=14 Harbour Lane, London
HOTEL_PHONE=+44 7700 900123
HOTEL_BOOKING_URL=https://grandhorizon.com/book
HOTEL_SLUG=grand-horizon

# WhatsApp — client's own account (Model B)
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta — client's own app
META_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxx
META_VERIFY_TOKEN=your_secure_verify_token_here

# Tawk.to
TAWKTO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAWKTO_PROPERTY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redis
REDIS_URL=redis://redis:6379

# n8n
N8N_PORT=5679
WEBHOOK_BASE_URL=https://grand-horizon.youragency.com
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_strong_password_here

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=/home/node/credentials/google-service-account.json
GOOGLE_SHEETS_ID=your_sheet_id_here

# Behaviour
DEFAULT_LANG=en
SUPPORTED_LANGS=en,fr,ar

# ── LEVEL 2 ADDITIONS ─────────────────────────────────────────

# Bot Engine
BOT_ENGINE_PORT=3001
SESSION_TTL_MINUTES=60

# PMS Integration
# PMS_TYPE options: native | cloudbeds | mews | opera
PMS_TYPE=native
PMS_API_BASE_URL=https://pms.grand-horizon.internal
INTERNAL_API_KEY=generate_strong_random_key_min_32_chars

# Room Hold
ROOM_HOLD_TTL_MINUTES=15

# Follow-Up
# Note: FOLLOW_UP_DELAY_MINUTES specifies the BullMQ delay for reminders
FOLLOW_UP_DELAY_MINUTES=60
DISCOUNT_CODE=BOOK10

# Upsell Prices (in client currency)
UPSELL_AIRPORT_PICKUP=25
UPSELL_BREAKFAST=15
UPSELL_EXTRA_BED=30
UPSELL_ROMANTIC=45
UPSELL_SPA=60

# Payment Gateway — client's own account
# PAYMENT_PROVIDER options: stripe | paystack | flutterwave
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Agency Tracker DB (Neon/Supabase managed PostgreSQL)
TRACKER_DB_URL=postgresql://user:password@host.neon.tech/tracker?sslmode=require
