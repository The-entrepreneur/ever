# ─────────────────────────────────────────────────────────────────────────────
# HCA (Hospitality Commerce Agent) — CLIENT CONFIG TEMPLATE
# HCA tier includes all GCE capabilities + F&B ordering, service requests,
# folio charge posting, and live PMS/POS integration.
# Never commit .env files to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Hotel Identity ───────────────────────────────────────────────────────────
HOTEL_NAME=The Grand Horizon
HOTEL_ADDRESS=14 Harbour Lane, London
HOTEL_PHONE=+44 7700 900123
HOTEL_BOOKING_URL=https://grandhorizon.com/book
HOTEL_SLUG=grand-horizon
HOTEL_CURRENCY=GBP
HOTEL_OPS_EMAIL=operations@grandhorizon.com
ENV=development
# ENV options: development | production

# ─── WhatsApp (OpenBSP) ───────────────────────────────────────────────────────
# Agency-level credentials live in the EVER backend .env, NOT here.
# Per-client values are auto-populated after the Embedded Signup flow completes.
WHATSAPP_PROVIDER=openbsp

# Per-hotel — written automatically by onboarding webhook. Do not set manually.
# PHONE_NUMBER_ID=                  ← Meta phone_number_id
# OPENBSP_VERIFY_TOKEN=             ← Generated by new-client.sh
# OPENBSP_ONBOARDING_TOKEN_ID=      ← Remove after connection confirmed

# Agency-level OpenBSP credentials (set in EVER backend, referenced here for reference)
# OPENBSP_BASE_URL=https://api.openbsp.dev
# OPENBSP_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
# OPENBSP_OWNER_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# ─── Meta (Instagram + Facebook) ─────────────────────────────────────────────
META_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxx
META_VERIFY_TOKEN=your_secure_verify_token_here

# ─── Tawk.to ─────────────────────────────────────────────────────────────────
TAWKTO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAWKTO_PROPERTY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── n8n ──────────────────────────────────────────────────────────────────────
N8N_PORT=5679
WEBHOOK_BASE_URL=https://grand-horizon.youragency.com
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_strong_password_here

# ─── Google Sheets ────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=/home/node/credentials/google-service-account.json
GOOGLE_SHEETS_ID=your_sheet_id_here

# ─── Language / Behaviour ─────────────────────────────────────────────────────
DEFAULT_LANG=en
SUPPORTED_LANGS=en,fr,ar

# ─── Bot Engine ───────────────────────────────────────────────────────────────
BOT_ENGINE_PORT=3001
BOT_ENGINE_URL=http://bot-engine:3001
SESSION_TTL_MINUTES=60
ROOM_HOLD_TTL_MINUTES=15
FOLLOW_UP_DELAY_MINUTES=60
DISCOUNT_CODE=BOOK10

# ─── Internal Network Security ────────────────────────────────────────────────
# Shared secret between n8n, bot-engine, and pms-api.
# Minimum 32 characters. Generate with: openssl rand -hex 32
INTERNAL_API_KEY=generate_strong_random_key_min_32_chars_here

# ─── PMS Database (per-hotel local PostgreSQL) ────────────────────────────────
PMS_DATABASE_URL=postgresql://user:password@postgres:5432/hotel_pms

# ─── POS / PMS Integration (pos_adapter.py) ──────────────────────────────────
# POS_INTEGRATION_TYPE options:
#   rest      → RESTful PMS API (Cloudbeds, Mews, Apaleo, etc.)
#   soap      → Legacy SOAP/XML PMS (Opera, older Micros)
#   webhook   → Push events to a PMS receiver endpoint
#   fallback  → No live integration; manual posting only (safe default)
POS_INTEGRATION_TYPE=fallback

# Required if POS_INTEGRATION_TYPE=rest:
# POS_REST_BASE_URL=https://api.yourhms.com
# POS_REST_AUTH_HEADER=Bearer your_api_token_here

# Required if POS_INTEGRATION_TYPE=soap:
# POS_SOAP_WSDL=http://legacy-pms.hotel.local/FolioService?wsdl

# Required if POS_INTEGRATION_TYPE=webhook:
# POS_WEBHOOK_URL=https://pms-receiver.hotel.com/folio-events

# Order settings
ORDER_ETA_MINUTES=20

# ─── Supabase (Agency Tracker) ────────────────────────────────────────────────
# Used by pos_adapter.py to write folio_charges audit records.
# The SERVICE ROLE KEY must be used here — NOT the anon key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.service_role_key_here

# ─── Staff Notifications ──────────────────────────────────────────────────────
# Used by services.py to alert hotel staff of incoming service requests.
# Priority: SLACK_WEBHOOK_URL (if set) → STAFF_WHATSAPP_NUMBER (fallback)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/xxxxxxxxxxxxxxxxxxxx

# If no Slack, staff are notified via WhatsApp using OpenBSP:
STAFF_WHATSAPP_NUMBER=+447700900456

# ─── Payment Gateway ──────────────────────────────────────────────────────────
# PAYMENT_PROVIDER options: paystack | flutterwave
# Stripe is used only for Stripe Checkout links (no Stripe Elements server-side code)
PAYMENT_PROVIDER=paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret_key_here
FLUTTERWAVE_SECRET_HASH=your_flutterwave_webhook_secret_hash_here

# ─── Upsell Prices (in hotel currency) ───────────────────────────────────────
UPSELL_AIRPORT_PICKUP=25
UPSELL_BREAKFAST=15
UPSELL_EXTRA_BED=30
UPSELL_ROMANTIC=45
UPSELL_SPA=60

# ─── Agency Tracker DB ────────────────────────────────────────────────────────
TRACKER_DB_URL=postgresql://user:password@host.neon.tech/tracker?sslmode=require

# ─── Dashboard / PWA Integration ─────────────────────────────────────────────
DASHBOARD_PUSH_URL=https://dashboard.youragency.com/api/push
# VAPID keys for Web Push Notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:admin@youragency.com
