# ─────────────────────────────────────────────────────────────────────────────
# EVER BASE SERVICES — MASTER ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to `.env` in your deployment or microservice environment.
# Never commit actual `.env` files containing live secrets to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Hotel / Property Identity ───────────────────────────────────────────────
HOTEL_NAME="The Grand Horizon"
HOTEL_SLUG="grand-horizon"
HOTEL_CURRENCY="GBP"
HOTEL_ADDRESS="14 Harbour Lane, London"
HOTEL_PHONE="+447700900123"
HOTEL_OPS_EMAIL="operations@grandhorizon.com"
ENV="development" # development | production

# ─── OpenBSP WhatsApp & Messaging Provider ──────────────────────────────────
WHATSAPP_PROVIDER="openbsp"
OPENBSP_BASE_URL="https://your-openbsp-instance.supabase.co"
OPENBSP_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"
OPENBSP_OWNER_API_KEY="sk_live_xxxxxxxxxxxxxxxxxxxx"
OPENBSP_ORGANIZATION_ID="00000000-0000-0000-0000-000000000000"

# Per-hotel phone ID (populated automatically after Meta Embedded Signup)
PHONE_NUMBER_ID=""

# ─── Meta Integration (Instagram / Messenger) ───────────────────────────────
META_PAGE_ACCESS_TOKEN="EAAxxxxxxxxxxxxxxxxxxxxxxx"
META_VERIFY_TOKEN="your_secure_verify_token_here"

# ─── Redis Cache & Handoff Lock ─────────────────────────────────────────────
REDIS_URL="redis://redis:6379"

# ─── Internal Network Security ──────────────────────────────────────────────
# Shared secret required for requests between n8n, bot-engine, and pms-api
# Generate a strong 32+ char key with: `openssl rand -hex 32`
INTERNAL_API_KEY="generate_strong_random_key_min_32_chars_here"

# ─── Bot Engine Configuration ───────────────────────────────────────────────
BOT_ENGINE_PORT=3001
BOT_ENGINE_URL="http://bot-engine:3001"
SESSION_TTL_MINUTES=60
ROOM_HOLD_TTL_MINUTES=15
FOLLOW_UP_DELAY_MINUTES=60
DISCOUNT_CODE="BOOK10"

# ─── PMS API & Database ──────────────────────────────────────────────────────
PMS_DATABASE_URL="postgresql://user:password@postgres:5432/hotel_pms"

# ─── POS Integration (pos_adapter.py) ────────────────────────────────────────
# POS_INTEGRATION_TYPE options: rest | soap | webhook | fallback
POS_INTEGRATION_TYPE="fallback"

# Required if POS_INTEGRATION_TYPE=rest:
# POS_REST_BASE_URL="https://api.yourhms.com"
# POS_REST_AUTH_HEADER="Bearer your_api_token_here"

# Required if POS_INTEGRATION_TYPE=soap:
# POS_SOAP_WSDL="http://legacy-pms.hotel.local/FolioService?wsdl"

# Required if POS_INTEGRATION_TYPE=webhook:
# POS_WEBHOOK_URL="https://pms-receiver.hotel.com/folio-events"

ORDER_ETA_MINUTES=20

# ─── Supabase Audit Trail (Agency Tracker) ─────────────────────────────────
# Used by pos_adapter.py to record folio_charges audit records.
# Requires the SERVICE ROLE KEY (not anon key).
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.service_role_key_here"

# ─── Staff Alerts & Notifications ───────────────────────────────────────────
SLACK_WEBHOOK_URL=""
STAFF_WHATSAPP_NUMBER=""

# ─── Payment Gateway Configuration ──────────────────────────────────────────
# PAYMENT_PROVIDER options: paystack | flutterwave | stripe
PAYMENT_PROVIDER="paystack"
PAYSTACK_SECRET_KEY="sk_test_your_paystack_secret_key_here"
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-your_flutterwave_secret_key_here"
FLUTTERWAVE_SECRET_HASH="your_flutterwave_webhook_secret_hash_here"

# ─── Upsell Rates (in hotel currency) ───────────────────────────────────────
UPSELL_AIRPORT_PICKUP=25
UPSELL_BREAKFAST=15
UPSELL_EXTRA_BED=30
UPSELL_ROMANTIC=45
UPSELL_SPA=60

# ─── n8n Automation Orchestration ──────────────────────────────────────────
N8N_PORT=5679
WEBHOOK_BASE_URL="https://grand-horizon.youragency.com"
N8N_BASIC_AUTH_USER="admin"
N8N_BASIC_AUTH_PASSWORD="changeme_strong_password_here"
