            "hero_headline_layer",
            "primary_action_row",
            "interactive_visual_workspace",
            "secondary_value_proposition_row",
            "integration_brand_pills"
          ]
        },
        "right_sidebar_pane": {
          "width_span": "w-full md:w-[30%] p-6 md:p-12 flex flex-col gap-12",
          "sections": [
            "sidebar_pitch_block",
            "bento_operation_pill_grid",
            "solutions_engineer_hire_pill",
            "pms_coverage_indicator_block",
            "interactive_guest_persona_dropdown"
          ]
        }
      }
    }
  },
  "components_specification": {
    "header_navbar_translation": {
      "left_logos": {
        "icon": "Ever dynamic wireframe symbol",
        "text": "Ever Cloud"
      },
