{
  "system_branding": {
    "brand_name": "Ever",
    "theme": "Studio Wireframe Editorial (Tech-Nordic Light)",
    "primary_accent": "#EA6639",
    "secondary_accent": "#7C3AED",
    "background_base": "#F9F6F0"
  },
  "layout_grid": {
    "outer_container": "max-w-full mx-auto bg-[#F9F6F0] min-h-screen text-zinc-900 relative flex",
    "columns": {
      "left_gutter": {
        "width_span": "hidden md:flex w-[60px] flex-col items-center justify-between py-8 border-r border-[#111111]/10 shrink-0",
